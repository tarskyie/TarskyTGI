<Page
    x:Class="TarskyTGI.Pages.OpenAiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat History -->
        <ListBox Grid.Row="0" Grid.Column="0" x:Name="ChatHistory" Margin="12,0,12,0"
                 Background="Transparent" SelectionChanged="ChatHistory_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="4,8" FontSize="14"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Input Bar -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="12,8,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="PromptBox"
                     PlaceholderText="Type a message (Enter to send, Shift+Enter for new line)"
                     PreviewKeyDown="PromptBox_KeyDown"
                     MinHeight="54"
                     MaxHeight="180"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top"/>

            <Button Content="Send" Click="SendFN" Style="{StaticResource AccentButtonStyle}"
                    Height="54" Width="82" Margin="10,0,0,0" Grid.Column="1"/>
            <Button Content="Clear" Click="ClearFN" Height="54" Width="82" Margin="8,0,0,0" Grid.Column="2"/>
        </Grid>

        <!-- Sidebar -->
        <ScrollViewer Grid.Column="1" Grid.RowSpan="2" Padding="10,0,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <TextBox x:Name="StatusTextBlock" Text="Ready." IsReadOnly="True" Background="#11FFFFFF"/>

                <MenuFlyoutSeparator/>

                <Expander Header="Connection parameters" HorizontalAlignment="Stretch" IsExpanded="False">
                    <StackPanel Spacing="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="API Key" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_PasswordChanged"
                 PlaceholderText="sk-... or gsk_..."/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Base URL" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBox x:Name="BaseUrlBox" Text="https://api.openai.com/v1"
             TextChanged="BaseUrlBox_TextChanged"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Model" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBox x:Name="ModelBox" Text="gpt-4o-mini"
             TextChanged="ModelBox_TextChanged"
             PlaceholderText="gpt-4o, llama-3.1-70b-versatile, mixtral..."/>
                        </StackPanel>
                    </StackPanel>
                </Expander>
                <MenuFlyoutSeparator/>

                <!-- System Prompt -->
                <StackPanel Spacing="4">
                    <TextBlock Text="System Prompt" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                    <TextBox x:Name="systemPromptTextBox" Height="110" AcceptsReturn="True" TextWrapping="Wrap"
                             TextChanged="systemPromptTextBox_TextChanged"
                             PlaceholderText="You are a helpful assistant..."/>
                </StackPanel>

                <MenuFlyoutSeparator/>

                <!-- Generation Parameters -->
                <TextBlock Text="Generation Parameters" Style="{StaticResource BodyStrongTextBlockStyle}"/>

                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Temperature" VerticalAlignment="Center"/>
                        <TextBox x:Name="temperatureBox" Text="0.8" Width="64" TextChanged="temperatureBox_TextChanged"
                                 BeforeTextChanging="TextBox2_BeforeTextChanging" Grid.Column="1"/>
                    </Grid>
                    <Slider x:Name="temperatureSlider" ValueChanged="temperatureSlider_ValueChanged" Minimum="0" Maximum="2" Value="0.8" StepFrequency="0.05"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Top P" VerticalAlignment="Center"/>
                        <TextBox x:Name="toppBox" Text="0.95" Width="64" TextChanged="toppBox_TextChanged"
                                 BeforeTextChanging="TextBox2_BeforeTextChanging" Grid.Column="1"/>
                    </Grid>
                    <Slider x:Name="toppSlider" ValueChanged="toppSlider_ValueChanged" Minimum="0" Maximum="1" Value="0.95" StepFrequency="0.01"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>